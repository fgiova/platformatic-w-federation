{
  "$schema": "https://schemas.platformatic.dev/@platformatic/runtime/3.19.0.json",
  "watch": true,
  "applications": [
    {
      "id": "users-service",
      "path": "./web/users-service"
    },
    {
      "id": "posts-service",
      "path": "./web/posts-service"
    },
    {
      "id": "reviews-service",
      "path": "./web/reviews-service"
    },
    {
      "id": "public-gateway",
      "path": "./web/public-gateway"
    }
  ],
  "logger": {
    "level": "{PLT_SERVER_LOGGER_LEVEL}"
  },
  "server": {
    "hostname": "{PLT_SERVER_HOSTNAME}",
    "port": "{PORT}"
  },
  "managementApi": "{PLT_MANAGEMENT_API}",
  "entrypoint": "public-gateway"
}
